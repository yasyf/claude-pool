# Build artifacts (anchored to repo root so cmd/cc-pool/ is NOT ignored)
/dist/
/build/
/cc-pool
/ccp
*.test
*.out
coverage.txt

# Local state that should never be committed
*.db
*.db-wal
*.db-shm
*.sock
*.log

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Go
/vendor/

# Swift widget (regenerated by `xcodegen generate`)
/widget/*.xcodeproj
/widget/Generated/
/widget/build/

# Python (hook bytecode)
__pycache__/
*.pyc

# Claude Code
.claude/settings.local.json
.context/
.env*
